PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/foodDB
JWT_SECRET=replace_with_secure_secret

# Razorpay (https://dashboard.razorpay.com/app/keys) — use Test keys for development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# First admin (npm run seed:admin). Override defaults in .env for production.
ADMIN_EMAIL=admin@etenrennen.local
ADMIN_PASSWORD=ChangeMeAdmin!
ADMIN_NAME=Admin
